# SiliconFlow API配置
# 用于VLM(视觉语言模型)识别和LLM文本分析

# VLM API配置（视觉语言模型识别）
VLM_API_URL=https://api.siliconflow.cn/v1/chat/completions
VLM_API_KEY=your_vlm_api_key_here
VLM_MODEL=Qwen/Qwen3-VL-32B-Instruct
VLM_TIMEOUT=180
VLM_RETRIES=1

# LLM API配置（文本语义分析）
LLM_API_URL=https://api.siliconflow.cn/v1/chat/completions
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=Pro/moonshotai/Kimi-K2.5
LLM_TIMEOUT=180
LLM_RETRIES=2

# 调试选项
DEBUG_LOG=1
DEBUG_LOG_REQUEST_BODY=1
DEBUG_LOG_MAX_CHARS=2000
